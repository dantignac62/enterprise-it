{
  "$schema": "./Set-CipherSuiteHardening.manifest.schema.json",
  "name": "CipherSuiteHardening",
  "version": "1.0.0",
  "description": "Switch-style manifest for SCHANNEL protocol, cipher, and hash hardening. Each entry's 'enabled' flag controls whether the script applies the entry; for protocols, 'clientEnabled' / 'serverEnabled' / 'disabledByDefault' declare the desired state; for ciphers and hashes, 'state' is 'Enabled' or 'Disabled'. Disabled entries are recorded as SKIPPED_BY_MANIFEST in the change ledger.",
  "lastModifiedUtc": "2026-04-26T00:00:00Z",

  "protocols": [
    { "name": "PCT 1.0",                     "description": "PCT 1.0 (legacy, broken)",        "clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "Multi-Protocol Unified Hello","description": "Multi-Protocol Unified Hello (legacy)","clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "SSL 2.0",                     "description": "SSL 2.0 (broken)",                "clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "SSL 3.0",                     "description": "SSL 3.0 (POODLE)",                "clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "TLS 1.0",                     "description": "TLS 1.0 (deprecated)",            "clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "TLS 1.1",                     "description": "TLS 1.1 (deprecated)",            "clientEnabled": false, "serverEnabled": false, "disabledByDefault": true,  "enabled": true },
    { "name": "TLS 1.2",                     "description": "TLS 1.2 (modern)",                "clientEnabled": true,  "serverEnabled": true,  "disabledByDefault": false, "enabled": true },
    { "name": "TLS 1.3",                     "description": "TLS 1.3 (modern)",                "clientEnabled": true,  "serverEnabled": true,  "disabledByDefault": false, "enabled": true }
  ],

  "ciphers": [
    { "name": "NULL",           "description": "NULL cipher (no encryption)",          "state": "Disabled", "enabled": true },
    { "name": "DES 56/56",      "description": "DES 56-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC2 40/128",     "description": "RC2 40-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC2 56/128",     "description": "RC2 56-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC2 128/128",    "description": "RC2 128-bit (deprecated)",             "state": "Disabled", "enabled": true },
    { "name": "RC4 40/128",     "description": "RC4 40-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC4 56/128",     "description": "RC4 56-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC4 64/128",     "description": "RC4 64-bit (broken)",                  "state": "Disabled", "enabled": true },
    { "name": "RC4 128/128",    "description": "RC4 128-bit (deprecated)",             "state": "Disabled", "enabled": true },
    { "name": "Triple DES 168", "description": "3DES 168-bit (Sweet32 vulnerability)", "state": "Disabled", "enabled": true },
    { "name": "AES 128/128",    "description": "AES 128-bit",                          "state": "Enabled",  "enabled": true },
    { "name": "AES 256/256",    "description": "AES 256-bit",                          "state": "Enabled",  "enabled": true }
  ],

  "hashes": [
    { "name": "MD5",    "description": "MD5 (broken)",                                                                                             "state": "Disabled", "enabled": true  },
    { "name": "SHA",    "description": "SHA-1 - preserved for cert-chain compatibility. Run a certificate inventory before flipping enabled=true.","state": "Disabled", "enabled": false },
    { "name": "SHA256", "description": "SHA-256",                                                                                                   "state": "Enabled",  "enabled": true  },
    { "name": "SHA384", "description": "SHA-384",                                                                                                   "state": "Enabled",  "enabled": true  },
    { "name": "SHA512", "description": "SHA-512",                                                                                                   "state": "Enabled",  "enabled": true  }
